generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "pharmacy"]
}

// ─── Enums — Auth ────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PHARMACIST
  CASHIER
  TECHNICIAN

  @@schema("auth")
}

enum ShiftStatus {
  OPEN
  CLOSED

  @@schema("auth")
}

// ─── Enums — Pharmacy ────────────────────────────────────────────────────────

enum ProductCategory {
  OTC
  PRESCRIPTION
  CONTROLLED
  COSMETIC
  SUPPLEMENT
  OTHER

  @@schema("pharmacy")
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
  RETURN

  @@schema("pharmacy")
}

enum PurchaseOrderStatus {
  PENDING
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED

  @@schema("pharmacy")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR

  @@schema("pharmacy")
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED

  @@schema("pharmacy")
}

enum ReturnType {
  FULL
  PARTIAL

  @@schema("pharmacy")
}

enum ControlledType {
  NONE
  SCHEDULE_I
  SCHEDULE_II
  SCHEDULE_III
  SCHEDULE_IV

  @@schema("pharmacy")
}

// ─── Auth — Roles & Users ────────────────────────────────────────────────────

model Role {
  name        UserRole @id @map("name")
  description String?
  users       User[]

  @@map("roles")
  @@schema("auth")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  full_name    String    @map("full_name")
  ci           String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @relation(fields: [roleName], references: [name])
  roleName     UserRole  @map("role_name")
  reg_number   String?   @map("reg_number")
  active       Boolean   @default(true)
  deleted_at   DateTime? @map("deleted_at")
  last_login   DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  shifts               Shift[]
  inventoryMovements   InventoryMovement[] @relation("MovementUser")
  approvedMovements    InventoryMovement[] @relation("MovementApprovedBy")
  purchaseOrders       PurchaseOrder[]
  sales                Sale[]
  returns              Return[]
  configUpdates        Config[]            @relation("ConfigUpdatedBy")

  @@map("users")
  @@schema("auth")
}

// ─── Auth — Shifts ───────────────────────────────────────────────────────────

model Shift {
  id            String      @id @default(uuid()) @db.Uuid
  user_id       String      @map("user_id") @db.Uuid
  opening_cash  Decimal     @map("opening_cash") @db.Decimal(12, 2)
  closing_cash  Decimal?    @map("closing_cash") @db.Decimal(12, 2)
  expected_cash Decimal?    @map("expected_cash") @db.Decimal(12, 2)
  status        ShiftStatus @default(OPEN)
  opened_at     DateTime    @default(now()) @map("opened_at")
  closed_at     DateTime?   @map("closed_at")

  user  User   @relation(fields: [user_id], references: [id])
  sales Sale[]

  @@map("shifts")
  @@schema("auth")
}

// ─── Pharmacy — Products & Inventory ─────────────────────────────────────────

model Product {
  id                String          @id @default(uuid()) @db.Uuid
  dci_name          String          @map("dci_name")
  commercial_name   String          @map("commercial_name")
  laboratory        String?
  form              String?
  concentration     String?
  barcode           String?         @unique
  category          ProductCategory @default(OTHER)
  sale_price        Decimal         @map("sale_price") @db.Decimal(12, 2)
  cost_price        Decimal         @map("cost_price") @db.Decimal(12, 2)
  min_stock         Int             @default(0) @map("min_stock")
  active            Boolean         @default(true)
  deleted_at        DateTime?       @map("deleted_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  lots                 Lot[]
  inventoryMovements   InventoryMovement[]
  orderItems           OrderItem[]
  saleItems            SaleItem[]

  @@map("products")
  @@schema("pharmacy")
}

model Lot {
  id          String    @id @default(uuid()) @db.Uuid
  product_id  String    @map("product_id") @db.Uuid
  lot_number  String    @map("lot_number")
  expiry_date DateTime  @map("expiry_date") @db.Date
  initial_qty Int       @map("initial_qty")
  current_qty Int       @map("current_qty")
  created_at  DateTime  @default(now()) @map("created_at")

  product            Product[]
  inventoryMovements InventoryMovement[]
  saleItems          SaleItem[]
  returnItems        ReturnItem[]

  @@map("lots")
  @@schema("pharmacy")
}

model InventoryMovement {
  id           String       @id @default(uuid()) @db.Uuid
  product_id   String       @map("product_id") @db.Uuid
  lot_id       String       @map("lot_id") @db.Uuid
  user_id      String       @map("user_id") @db.Uuid
  movementType MovementType @map("movement_type")
  quantity     Int
  reason       String?
  approved_by  String?      @map("approved_by") @db.Uuid
  created_at   DateTime     @default(now()) @map("created_at")

  product    Product @relation(fields: [product_id], references: [id])
  lot        Lot     @relation(fields: [lot_id], references: [id])
  user       User    @relation("MovementUser", fields: [user_id], references: [id])
  approver   User?   @relation("MovementApprovedBy", fields: [approved_by], references: [id])

  @@index([product_id])
  @@index([lot_id])
  @@index([user_id])
  @@map("inventory_movements")
  @@schema("pharmacy")
}

// ─── Pharmacy — Suppliers & Purchasing ───────────────────────────────────────

model Supplier {
  id             String  @id @default(uuid()) @db.Uuid
  name           String
  nit            String  @unique
  address        String?
  city           String?
  contact_person String? @map("contact_person")
  phone          String?
  email          String?
  payment_terms  String? @map("payment_terms")
  active         Boolean @default(true)

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
  @@schema("pharmacy")
}

model PurchaseOrder {
  id             String               @id @default(uuid()) @db.Uuid
  supplier_id    String               @map("supplier_id") @db.Uuid
  user_id        String               @map("user_id") @db.Uuid
  status         PurchaseOrderStatus  @default(PENDING)
  invoice_number String?              @map("invoice_number")
  order_date     DateTime             @map("order_date") @db.Date
  created_at     DateTime             @default(now()) @map("created_at")

  supplier   Supplier    @relation(fields: [supplier_id], references: [id])
  user       User        @relation(fields: [user_id], references: [id])
  orderItems OrderItem[]

  @@index([supplier_id])
  @@index([user_id])
  @@map("purchase_orders")
  @@schema("pharmacy")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  order_id    String  @map("order_id") @db.Uuid
  product_id  String  @map("product_id") @db.Uuid
  qty_ordered Int     @map("qty_ordered")
  qty_received Int    @default(0) @map("qty_received")
  unit_cost   Decimal @map("unit_cost") @db.Decimal(12, 2)
  lot_number  String? @map("lot_number")
  expiry_date DateTime? @map("expiry_date") @db.Date

  order   PurchaseOrder @relation(fields: [order_id], references: [id])
  product Product       @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
  @@schema("pharmacy")
}

// ─── Pharmacy — Sales ────────────────────────────────────────────────────────

model Sale {
  id             String        @id @default(uuid()) @db.Uuid
  shift_id       String        @map("shift_id") @db.Uuid
  user_id        String        @map("user_id") @db.Uuid
  receipt_number String        @unique @map("receipt_number")
  subtotal       Decimal       @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @map("payment_method")
  cash_received  Decimal       @default(0) @map("cash_received") @db.Decimal(12, 2)
  change_given   Decimal       @default(0) @map("change_given") @db.Decimal(12, 2)
  status         SaleStatus    @default(COMPLETED)
  created_at     DateTime      @default(now()) @map("created_at")

  shift         Shift           @relation(fields: [shift_id], references: [id])
  user          User            @relation(fields: [user_id], references: [id])
  saleItems     SaleItem[]
  returns       Return[]
  prescriptions Prescription[]

  @@index([shift_id])
  @@index([user_id])
  @@index([created_at])
  @@map("sales")
  @@schema("pharmacy")
}

model SaleItem {
  id          String  @id @default(uuid()) @db.Uuid
  sale_id     String  @map("sale_id") @db.Uuid
  product_id  String  @map("product_id") @db.Uuid
  lot_id      String  @map("lot_id") @db.Uuid
  quantity    Int
  unit_price  Decimal @map("unit_price") @db.Decimal(12, 2)
  line_total  Decimal @map("line_total") @db.Decimal(12, 2)

  sale        Sale      @relation(fields: [sale_id], references: [id])
  product     Product   @relation(fields: [product_id], references: [id])
  lot         Lot       @relation(fields: [lot_id], references: [id])
  returnItems ReturnItem[]

  @@index([sale_id])
  @@index([product_id])
  @@index([lot_id])
  @@map("sale_items")
  @@schema("pharmacy")
}

// ─── Pharmacy — Returns ──────────────────────────────────────────────────────

model Return {
  id         String     @id @default(uuid()) @db.Uuid
  sale_id    String     @map("sale_id") @db.Uuid
  user_id    String     @map("user_id") @db.Uuid
  reason     String
  returnType ReturnType @map("return_type")
  created_at DateTime   @default(now()) @map("created_at")

  sale        Sale         @relation(fields: [sale_id], references: [id])
  user        User         @relation(fields: [user_id], references: [id])
  returnItems ReturnItem[]

  @@index([sale_id])
  @@index([user_id])
  @@map("returns")
  @@schema("pharmacy")
}

model ReturnItem {
  id           String @id @default(uuid()) @db.Uuid
  return_id    String @map("return_id") @db.Uuid
  sale_item_id String @map("sale_item_id") @db.Uuid
  lot_id       String @map("lot_id") @db.Uuid
  quantity     Int

  return    Return   @relation(fields: [return_id], references: [id])
  saleItem  SaleItem @relation(fields: [sale_item_id], references: [id])
  lot       Lot      @relation(fields: [lot_id], references: [id])

  @@index([return_id])
  @@index([sale_item_id])
  @@index([lot_id])
  @@map("return_items")
  @@schema("pharmacy")
}

// ─── Pharmacy — Prescriptions & Doctors ──────────────────────────────────────

model Doctor {
  id          String  @id @default(uuid()) @db.Uuid
  full_name   String  @map("full_name")
  reg_number  String  @unique @map("reg_number")
  specialty   String?
  phone       String?
  email       String?
  active      Boolean @default(true)

  prescriptions Prescription[]

  @@map("doctors")
  @@schema("pharmacy")
}

model Prescription {
  id              String         @id @default(uuid()) @db.Uuid
  sale_id         String         @map("sale_id") @db.Uuid
  doctor_id       String         @map("doctor_id") @db.Uuid
  patient_name    String         @map("patient_name")
  patient_ci      String         @map("patient_ci")
  rx_date         DateTime       @map("rx_date") @db.Date
  rx_number       String         @unique @map("rx_number")
  image_path      String?        @map("image_path")
  controlledType  ControlledType @default(NONE) @map("controlled_type")
  created_at      DateTime       @default(now()) @map("created_at")

  sale   Sale   @relation(fields: [sale_id], references: [id])
  doctor Doctor @relation(fields: [doctor_id], references: [id])

  @@index([sale_id])
  @@index([doctor_id])
  @@map("prescriptions")
  @@schema("pharmacy")
}

// ─── Pharmacy — Config ───────────────────────────────────────────────────────

model Config {
  id         String    @id @default(uuid()) @db.Uuid
  key        String    @unique
  value      String    @db.Text
  encrypted  Boolean   @default(false)
  updated_at DateTime  @updatedAt @map("updated_at")
  updated_by String?   @map("updated_by") @db.Uuid

  updater User? @relation("ConfigUpdatedBy", fields: [updated_by], references: [id])

  @@map("config")
  @@schema("pharmacy")
}
