# =============================================================================
# openPharmacy API – environment variables template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for your environment.
# `.env` is git-ignored; only `.env.example` is tracked.
#
# Generate strong secrets with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# =============================================================================


# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Credentials used by the local docker-compose Postgres service.
POSTGRES_USER=openpharmacy
POSTGRES_PASSWORD=openpharmacy
POSTGRES_DB=openpharmacy
POSTGRES_PORT=5432

# Prisma datasource URL. Must use the same credentials as above.
# In production, point this at your managed Postgres host.
DATABASE_URL=postgresql://openpharmacy:openpharmacy@localhost:5432/openpharmacy?schema=public


# ─── App runtime ────────────────────────────────────────────────────────────
# One of: development | production | test
NODE_ENV=development

# HTTP port the API listens on.
PORT=3000

# Comma-separated list of origins allowed by CORS. Use the FE dev server in
# dev, your real domain in production. The FE must send credentials.
CORS_ORIGIN=http://localhost:4200


# ─── Cookie signing ─────────────────────────────────────────────────────────
# Used by cookie-parser to sign the refresh-token cookie.
# 8+ chars. Rotate to invalidate every active session at once.
COOKIE_SECRET=change-me-in-production


# ─── Password hashing ───────────────────────────────────────────────────────
# bcrypt cost factor. 12 ≈ 250 ms per hash on a modern CPU.
# Bump to 13+ as hardware gets faster; never go below 10.
BCRYPT_SALT_ROUNDS=12


# ─── JWT (access token) ─────────────────────────────────────────────────────
# 32+ chars. Used to sign and verify short-lived access tokens.
# ROTATE this value to invalidate every outstanding access token.
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long

# How long an access token is valid. Accepts ms | s | m | h | d.
# Short-lived (minutes) is the secure default; the ticket specifies 8h.
JWT_ACCESS_TTL=8h


# ─── JWT (refresh token) ────────────────────────────────────────────────────
# 32+ chars. MUST be different from JWT_ACCESS_SECRET so a leaked access
# secret cannot be used to forge refresh tokens (and vice versa).
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long

# How long a refresh token is valid. Accepts ms | s | m | h | d.
# The refresh token is also persisted server-side (hashed jti) and can be
# revoked before expiry; see RefreshToken table.
JWT_REFRESH_TTL=7d


# ─── Account lockout ────────────────────────────────────────────────────────
# Number of consecutive failed login attempts before the account is locked.
LOCKOUT_MAX_ATTEMPTS=5

# How long the account stays locked, in minutes. After this period a new
# attempt resets the counter on the next successful login.
LOCKOUT_DURATION_MIN=15


# ─── Rate limiting (global tiers) ───────────────────────────────────────────
# Three sliding-window tiers enforced by @nestjs/throttler. A request counts
# against all three; it must be under every limit to pass.
#
# short:  per-second cap (burst protection)
# medium: per-10s cap
# long:   per-minute cap

# Window length in milliseconds.
THROTTLE_SHORT_TTL=1000
THROTTLE_MEDIUM_TTL=10000
THROTTLE_LONG_TTL=60000

# Max requests per IP inside the window above.
THROTTLE_SHORT_LIMIT=3
THROTTLE_MEDIUM_LIMIT=20
THROTTLE_LONG_LIMIT=100


# ─── Rate limiting (login endpoint override) ────────────────────────────────
# POST /auth/login gets stricter per-IP limits on top of the global tiers.
# The lockout policy above is per-account; this one is per-IP.
THROTTLE_LOGIN_TTL=60000
THROTTLE_LOGIN_LIMIT=5
